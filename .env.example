# ===========================
# 匠物定制 - 环境变量配置
# 复制此文件为 .env 并填写实际值
# ===========================

# ---------- MySQL ----------
MYSQL_ROOT_PASSWORD=123456
MYSQL_DATABASE=jiangwu_custom

# ---------- JWT ----------
JWT_SECRET=jiangwu-custom-secret-key-must-be-at-least-256-bits-long-for-hs256

# ---------- AI Service ----------
# false = 使用 Mock 模式 (无需 API Key)
# true  = 使用真实 Qwen-VL (需要有效 API Key)
ENABLE_REAL_LLM=false
QWEN_API_KEY=sk-your-dashscope-api-key

# ---------- Milvus (可选，有默认值) ----------
# MILVUS_HOST=milvus
# MILVUS_PORT=19530
